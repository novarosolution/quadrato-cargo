# API base URL (Express in quadrato-cargo/server or repo-root server/)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4010
# Optional deploy proxy target:
# BACKEND_API_BASE_URL=https://api.your-domain.com
#
# MUST match API server ADMIN_API_SECRET exactly (same string in quadrato-cargo/server/.env or server/.env).
ADMIN_API_SECRET=local-dev-admin-api-secret-must-match-api-server-env

# Customer auth (NextAuth / Auth.js). Generate secret: openssl rand -base64 32
AUTH_SECRET="paste-a-long-random-string-here"
# Optional legacy name — used if AUTH_SECRET is empty or unset
# NEXTAUTH_SECRET="same-value-as-above"
# Production: public URL of this app
# AUTH_URL="https://your-domain.com"

# Admin panel at /admin/login — session signing (required, min 16 characters)
ADMIN_SECRET="min-32-chars-random-string-for-session-signing"
# Optional “super admin” login (single account from env). Team accounts are created in Admin → Users.
ADMIN_EMAIL="admin@yourcompany.com"
ADMIN_PASSWORD="change-me-to-a-long-random-password"

# Optional: protect read-only submission APIs
# API_READ_SECRET="generate-a-long-random-string"
