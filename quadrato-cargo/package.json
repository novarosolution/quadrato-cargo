{
  "name": "quadrato-cargo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/clear-next-dev-lock.mjs",
    "dev": "next dev --webpack",
    "dev:turbo": "node scripts/clear-next-dev-lock.mjs && next dev",
    "dev:fresh": "npm run clean && next dev --webpack",
    "dev:repair": "node scripts/clear-next-dev-lock.mjs --repair",
    "dev:reset": "node scripts/clear-next-dev-lock.mjs --repair && next dev --webpack",
    "dev:unlock": "node scripts/clear-next-dev-lock.mjs",
    "clean": "node scripts/clean-next.mjs",
    "build": "next build --webpack",
    "build:safe": "npm run clean && npm run build",
    "postbuild": "node scripts/ensure-routes-manifest-deterministic.mjs",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit --incremental false"
  },
  "dependencies": {
    "@react-three/fiber": "^9.5.0",
    "bcryptjs": "^3.0.3",
    "framer-motion": "^12.38.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.0.1",
    "next": "16.1.7",
    "next-auth": "^5.0.0-beta.30",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "three": "^0.183.2"
  },
  "overrides": {
    "@types/react-reconciler": "0.33.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.173.0",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "mongodb": "^7.1.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
